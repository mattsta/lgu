{
  "scenarios": [
    {
      "name": "coordinated_ua_threshold_row",
      "args": {
        "coord_window_seconds": 10.0,
        "coord_count": 3,
        "coord_unique_paths": 3,
        "coord_unique_ips": 3
      },
      "actors": {
        "bot_a": {"ip": "doc:1:80", "ua": "shared", "referer": "none"},
        "bot_b": {"ip": "doc:1:81", "ua": "shared", "referer": "none"},
        "bot_c": {"ip": "doc:1:82", "ua": "shared", "referer": "none"}
      },
      "events": [
        {"actor": "bot_a", "at": 0, "path": "/synthetic/scenario-coord-a"},
        {"actor": "bot_b", "at": 1, "path": "/synthetic/scenario-coord-b"},
        {"actor": "bot_c", "at": 2, "path": "/synthetic/scenario-coord-c"}
      ],
      "expect": {
        "batch": {
          "bots": ["bot_a", "bot_b", "bot_c"],
          "proofs": {
            "bot_a": ["coordinated-ua"],
            "bot_b": ["coordinated-ua"],
            "bot_c": ["coordinated-ua"]
          }
        },
        "live": {
          "emission_count": 1,
          "emissions": [
            {"actor": "bot_c", "action": "ban", "reasons": ["coordinated-ua"]}
          ],
          "no_emissions": ["bot_a", "bot_b"]
        }
      }
    },
