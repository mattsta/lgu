        {"actor": "bot_b", "at": 2, "path": "/synthetic/scenario-payload-b?render=full"},
        {"actor": "bot_c", "at": 3, "path": "/synthetic/scenario-payload-c?render=full"}
      ],
      "expect": {
        "batch": {
          "bots": ["bot_a", "bot_b", "bot_c"],
