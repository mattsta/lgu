        "bot_b": {"ip": "doc:3:81", "ua": "chrome_120", "referer": "none"},
        "bot_c": {"ip": "doc:3:82", "ua": "chrome_120", "referer": "none"},
        "clean": {"ip": "doc:3:83", "ua": "chrome_120", "referer": "none"}
      },
      "events": [
        {"actor": "clean", "at": 0, "path": "/synthetic/scenario-no-marker"},
