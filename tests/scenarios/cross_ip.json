            "bot_b": ["payload-campaign"],
            "bot_c": ["payload-campaign"]
          }
        },
        "live": {
          "emission_count": 1,
          "emissions": [
            {"actor": "bot_c", "action": "ban", "reasons": ["payload-campaign"]}
