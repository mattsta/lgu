        {"actor": "source", "at": 6, "path": "/synthetic/rotating-ua-c", "ua": "safari_17"},
        {"actor": "source", "at": 9, "path": "/synthetic/rotating-ua-d", "ua": "SyntheticBrowserA/1.0"},
        {"actor": "source", "at": 12, "path": "/synthetic/rotating-ua-e", "ua": "SyntheticBrowserB/1.0"},
        {"actor": "source", "at": 15, "path": "/synthetic/rotating-ua-f", "ua": "SyntheticBrowserC/1.0"}
