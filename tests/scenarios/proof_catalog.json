{
  "scenarios": [
    {
      "name": "payload_fuzzer_configured_marker_fires",
      "args": {
        "detector_config": {"payload_marker_patterns": ["synthetic_marker="]}
      },
      "actors": {
        "source": {"ip": "doc:3:120", "ua": "chrome_120", "referer": "none"}
      },
      "events": [
        {
          "actor": "source",
          "repeat": 12,
          "every": 1,
          "path": "/synthetic/payload-fuzzer?synthetic_marker=alpha&probe=union%20all%20select"
        }
      ],
      "expect": {
        "batch": {
          "bots": ["source"],
          "proofs": {"source": ["payload-fuzzer"]},
          "absent_proofs": {"source": ["serial-sweep", "same-second-ua-swap"]}
        },
        "live": {
          "emission_count": 1,
          "emissions": [
            {"actor": "source", "action": "ban", "reasons": ["payload-fuzzer"]}
          ]
        }
      }
    },
    {
      "name": "rapid_ua_switch_fires",
      "actors": {
        "source": {"ip": "doc:3:121", "ua": "chrome_120", "referer": "none"}
      },
      "events": [
        {"actor": "source", "at": 0, "path": "/synthetic/rapid-ua-a", "ua": "chrome_120"},
        {"actor": "source", "at": 0.5, "path": "/synthetic/rapid-ua-b", "ua": "firefox_122"}
      ],
      "expect": {
        "batch": {
          "bots": ["source"],
          "proofs": {"source": ["rapid-ua-switch"]},
          "absent_proofs": {"source": ["same-second-ua-swap"]}
        },
        "live": {
          "emission_count": 1,
          "emissions": [
            {"actor": "source", "action": "ban", "reasons": ["rapid-ua-switch"]}
          ]
        }
      }
    },
    {
