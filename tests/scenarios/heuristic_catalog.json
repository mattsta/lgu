      "name": "provider_hosted_activity_opt_in_fires",
      "args": {
        "provider_ranges": ["tests/fixtures/provider_ranges/synthetichost.csv"],
        "provider_watch": ["synthetichost"],
        "provider_request_count": 3,
        "provider_unique_paths": 3,
        "provider_min_score": 0.0,
        "emit_suspects": true
      },
      "actors": {
        "source": {"ip": "doc:1:211", "ua": "chrome_120", "referer": "none"},
        "clean": {"ip": "doc:2:211", "ua": "chrome_120", "referer": "none"}
      },
      "events": [
        {
          "actor": "source",
          "repeat": 3,
          "every": 1,
          "path_template": "/synthetic/provider-positive-{i:02d}"
        },
        {
          "actor": "clean",
          "at": 20,
          "repeat": 3,
          "every": 1,
          "path_template": "/synthetic/provider-negative-{i:02d}"
        }
      ],
      "expect": {
        "batch": {
          "bots": ["source"],
          "clean": ["clean"],
          "proofs": {"source": ["provider-hosted-activity"]},
          "absent_proofs": {"clean": ["provider-hosted-activity"]},
          "actions": {"source": "suspect", "clean": "clean"}
        },
        "live": {
          "emission_count": 1,
          "emissions": [
            {
              "actor": "source",
              "action": "suspect",
              "reasons": ["provider-hosted-activity"]
            }
          ],
          "no_emissions": ["clean"]
        }
