{
  "scenarios": [
    {
      "name": "known_ua_pattern_fires",
      "args": {
        "detector_config": {
          "known_bot_ua_patterns": ["SyntheticKnownBot"]
        }
      },
      "actors": {
        "source": {"ip": "doc:1:201", "ua": "SyntheticKnownBot/1.0", "referer": "none"},
        "clean": {"ip": "doc:1:202", "ua": "chrome_120", "referer": "none"}
      },
      "events": [
        {"actor": "source", "at": 0, "path": "/synthetic/known-ua-pattern"},
        {"actor": "clean", "at": 10, "path": "/synthetic/known-ua-clean"}
      ],
      "expect": {
        "batch": {
          "bots": ["source"],
          "clean": ["clean"],
          "reasons": {"source": ["known-ua-or-referer"]},
          "absent_reasons": {"clean": ["known-ua-or-referer"]},
          "actions": {"source": "ban", "clean": "clean"}
        },
        "live": {
          "emission_count": 1,
          "emissions": [
            {"actor": "source", "action": "ban", "reasons": ["known-ua-or-referer"]}
          ],
          "no_emissions": ["clean"]
        }
      }
    },
    {
      "name": "burst_threshold_fires_without_proofs",
      "args": {
        "multi_fetch_count": 100,
        "sweep_count": 100,
        "serial_count": 100,
        "ban_score": 999,
        "suspect_score": 999,
        "emit_suspects": true
      },
      "actors": {
        "source": {"ip": "doc:1:203", "ua": "chrome_120", "referer": "none"},
        "clean": {"ip": "doc:1:204", "ua": "chrome_120", "referer": "none"}
      },
      "events": [
        {
          "actor": "source",
          "repeat": 12,
          "every": 0.1,
          "path_template": "/synthetic/burst-positive-{i:02d}"
        },
        {
          "actor": "clean",
          "at": 20,
          "repeat": 11,
          "every": 0.1,
          "path_template": "/synthetic/burst-negative-{i:02d}"
        }
      ],
      "expect": {
        "batch": {
          "bots": ["source"],
          "clean": ["clean"],
          "reasons": {"source": ["burst"]},
          "absent_reasons": {"clean": ["burst"]},
          "actions": {"source": "suspect", "clean": "clean"}
        },
        "live": {
          "emission_count": 1,
          "emissions": [
            {"actor": "source", "action": "suspect", "reasons": ["burst"]}
          ],
          "no_emissions": ["clean"]
        }
      }
    },
