    {
      "name": "repeated_pair_below_threshold_stays_clean",
      "actors": {
        "source": {"ip": "doc:1:100", "ua": "chrome_120", "referer": "none"}
      },
      "events": [
        {
          "actor": "source",
          "repeat": 7,
          "every": 40,
          "events": [
            {"offset": 0, "path": "/synthetic/threshold-pair-alpha"},
            {"offset": 1, "path": "/synthetic/threshold-pair-beta"}
          ]
        }
      ],
      "expect": {
        "batch": {
          "clean": ["source"],
          "absent_proofs": {"source": ["repeated-pair"]}
        },
        "live": {
          "emission_count": 0,
          "no_emissions": ["source"]
        }
      }
    },
