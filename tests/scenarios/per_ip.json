{
  "scenarios": [
    {
      "name": "cadenced_repeat_hourly_same_path",
      "args": {"cadence_hour_repeat_count": 99},
      "actors": {
        "bot": {"ip": "doc:2:44", "ua": "chrome_133", "referer": "none"},
        "human": {"ip": "doc:1:44", "ua": "chrome_120", "referer": "referrer"}
      },
      "events": [
        {
          "actor": "bot",
          "repeat": 3,
          "every": 3660,
          "path": "/synthetic/scenario-cadenced-target"
        },
        {
          "actor": "human",
          "repeat": 4,
          "at": 120,
          "every": 95,
          "path_template": "/synthetic/scenario-human-read-{i:02d}"
        }
      ],
      "expect": {
        "batch": {
          "bots": ["bot"],
          "clean": ["human"],
          "proofs": {"bot": ["cadenced-repeat"]},
          "absent_proofs": {"human": ["cadenced-repeat", "tight-multifetch"]}
        },
        "live": {
          "emission_count": 1,
          "emissions": [
            {"actor": "bot", "action": "ban", "reasons": ["cadenced-repeat"]}
          ],
          "no_emissions": ["human"]
        }
      }
    },
